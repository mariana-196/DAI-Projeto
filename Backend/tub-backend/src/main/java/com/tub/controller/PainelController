package com.tub.controller;

import com.tub.model.DisplayPanel;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.List;

@RestController
@RequestMapping("/api/paineis")
@CrossOrigin(origins = "*") // Permite que o teu HTML (Frontend) fale com este Java
public class PainelController {

    // Lista temporária para testares o Frontend antes de ligarmos à Base de Dados (Linha 95)
    private List<DisplayPanel> mockPaineis = new ArrayList<>();

    // O Java corre este bloco logo ao iniciar para criar painéis de teste
    public PainelController() {
        DisplayPanel p1 = new DisplayPanel();
        p1.setPanelId("PMD-01"); 
        p1.setLocation("Avenida Central (Sentido N)"); 
        p1.setStatus("ONLINE"); 
        p1.setMessage("L43: 02 MIN | L02: 05 MIN");
        p1.setTimestamp(LocalDateTime.now());
        
        DisplayPanel p2 = new DisplayPanel();
        p2.setPanelId("PMD-02"); 
        p2.setLocation("Universidade do Minho (Campus)"); 
        p2.setStatus("ONLINE"); 
        p2.setMessage("L02: 01 MIN | L07: 12 MIN");
        p2.setTimestamp(LocalDateTime.now());

        DisplayPanel p3 = new DisplayPanel();
        p3.setPanelId("PMD-03"); 
        p3.setLocation("Estação CP (Interface)"); 
        p3.setStatus("ONLINE"); 
        p3.setMessage("L43: 08 MIN | L14: 15 MIN");
        p3.setTimestamp(LocalDateTime.now());

        mockPaineis.add(p1);
        mockPaineis.add(p2);
        mockPaineis.add(p3);
    }

    /**
     * Responde ao pedido GET: Envia a lista de painéis para o ecrã
     */
    @GetMapping
    public ResponseEntity<List<DisplayPanel>> listarPaineis() {
        // Mais tarde, a Linha 95 vai fazer isto ir buscar ao SQL
        return ResponseEntity.ok(mockPaineis);
    }

    /**
     * Responde ao pedido POST: Recebe a nova mensagem do ecrã e atualiza os painéis
     */
    @PostMapping("/publicar")
    public ResponseEntity<String> publicarMensagem(@RequestBody DisplayPanel dadosRecebidos) {
        
        String destino = dadosRecebidos.getPanelId();
        String novaMensagem = dadosRecebidos.getMessage();

        // Se o utilizador escolheu "TODOS" (Broadcast)
        if (destino.equals("TODOS")) {
            for (DisplayPanel painel : mockPaineis) {
                if (!painel.getStatus().equals("DEGRADADO")) {
                    painel.setMessage(novaMensagem);
                    painel.setTimestamp(LocalDateTime.now());
                }
            }
        } 
        // Se o utilizador escolheu apenas um painel específico
        else {
            for (DisplayPanel painel : mockPaineis) {
                if (painel.getPanelId().equals(destino)) {
                    painel.setMessage(novaMensagem);
                    painel.setTimestamp(LocalDateTime.now());
                    break;
                }
            }
        }
        
        return ResponseEntity.ok("{\"resultado\": \"Mensagem publicada com sucesso\"}");
    }
}